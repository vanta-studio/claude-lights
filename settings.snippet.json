{
  "//": "ClaudeLights hook wiring for MANUAL setup. Prefer the in-app installer (open ClaudeLights -> Install Hooks), which writes equivalent entries. The helper binary is installed by the app to ~/Library/Application Support/ClaudeLights/. Merge the \"hooks\" object below into your ~/.claude/settings.json. The [ -x ... ] guard makes each hook a silent no-op if the helper is ever removed; $HOME is expanded by the shell and the double quotes keep the space in 'Application Support' intact.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" ] && \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" working || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" ] && \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" needs_input || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" ] && \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" resume || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" ] && \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" done || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" ] && \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" compacting || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|agent_needs_input|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" ] && \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" needs_input || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -x \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" ] && \"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" remove || true"
          }
        ]
      }
    ]
  }
}
