{
  "//": "ClaudeLights hook wiring for MANUAL setup. Prefer the in-app installer (open ClaudeLights -> Install Hooks), which writes exactly these entries. The helper binary is installed by the app to ~/Library/Application Support/ClaudeLights/. Merge the \"hooks\" object below into your ~/.claude/settings.json; $HOME is expanded by the shell, and the double quotes keep the space in 'Application Support' intact.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" working"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" resume"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" done"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" compacting"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" needs_input"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/Library/Application Support/ClaudeLights/claudelights-hook\" remove"
          }
        ]
      }
    ]
  }
}
